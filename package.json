  "files": [
    "lib/**/*"
  ],
  "devDependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.1.1",
    "@types/jest": "^26.0.22",
    "@types/node": "^25.6.0",
    "@types/tmp": "^0.2.0",
    "@vercel/ncc": "^0.38.4",
    "dotenv": "^17.4.2",
    "jest": "^26.6.3",
    "jest-runtime": "^30.3.0",
    "prettier": "^3.8.3",
    "ts-jest": "^26.5.4",
    "ts-node": "^10.9.2",
    "typescript": "^4.2.3",
